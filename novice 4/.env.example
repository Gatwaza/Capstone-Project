# Novice — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# GNU GPL v3 — Jean Robert Gatwaza / ALU

# ── Umuganda TTS (Kinyarwanda) ────────────────────────────
# If self-hosting: set to http://localhost:5000
# If using cloud endpoint: set to the deployed URL
UMUGANDA_TTS_URL=http://localhost:5000

# ── Google Drive (dataset sync, optional for production)  ─
# Service account JSON path for CI/ML pipeline dataset download
GDRIVE_SERVICE_ACCOUNT_JSON=secrets/gdrive_service_account.json

# ── WandB (ML experiment tracking, optional) ─────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=novice-cpr-coach
WANDB_ENTITY=your_username_here

# ── App flags ─────────────────────────────────────────────
# Set to "true" to enable verbose pose/inference debug logging
DEBUG_POSE=false
DEBUG_INFERENCE=false
